# =============================================================================
# BuzzHub — environment variables
# Copy to `.env` (already gitignored) and fill in real values.
# =============================================================================

# ---- Database (Neon Postgres) ----
# Pooled connection used by the Prisma client at runtime.
POSTGRES_PRISMA_URL=

# Direct (non-pooling) connection used for `prisma migrate`.
POSTGRES_URL_NON_POOLING=

# ---- App ----
# Public base URL of the deployment (used for OAuth callback + emails).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- UploadThing ----
UPLOADTHING_SECRET=
NEXT_PUBLIC_UPLOADTHING_APP_ID=

# ---- Stream Chat / Video ----
NEXT_PUBLIC_STREAM_KEY=
STREAM_SECRET=
# Shared secret sent in the `x-webhook-secret` header by the Stream webhook.
STREAM_WEBHOOK_SECRET=

# ---- Cron / scheduled jobs ----
# NOTE: code reads CRON_SECRET (CLAUDE.md mentions CORN_SECRET — the code is correct).
CRON_SECRET=

# ---- Email (Brevo SMTP) ----
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BuzzHub <noreply@yourdomain.com>"
