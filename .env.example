# =============================================================================
# BuzzHub — environment variables
# Copy to `.env` (already gitignored) and fill in real values.
# =============================================================================

# ---- Database (Neon Postgres) ----
# Pooled connection used by the Prisma client at runtime.
POSTGRES_PRISMA_URL=

# Direct (non-pooling) connection used for `prisma migrate`.
POSTGRES_URL_NON_POOLING=

# ---- App ----
# Public base URL of the deployment (used for OAuth callback + emails).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- UploadThing ----
UPLOADTHING_SECRET=
NEXT_PUBLIC_UPLOADTHING_APP_ID=

# ---- Stream Chat / Video ----
NEXT_PUBLIC_STREAM_KEY=
STREAM_SECRET=
# Shared secret sent in the `x-webhook-secret` header by the Stream webhook.
STREAM_WEBHOOK_SECRET=

# ---- Cron / scheduled jobs ----
# NOTE: code reads CRON_SECRET (CLAUDE.md mentions CORN_SECRET — the code is correct).
CRON_SECRET=

# ---- Email (Brevo SMTP) ----
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BuzzHub <noreply@yourdomain.com>"

# ---- Stripe (required for billing) ----
# Live keys in production. STRIPE_WEBHOOK_SECRET is the signing secret
# of the webhook endpoint registered at /api/billing/webhook.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_VERIFIED=
STRIPE_WEBHOOK_SECRET=

# ---- Web Push (required for push notifications) ----
# Generate once with: node scripts/setup-vapid.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ---- Redis cache (optional) ----
# If unset, src/lib/cache.ts no-ops and the app falls through to the DB.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---- Sentry (optional) ----
# Without a DSN, Sentry.init silently no-ops. SENTRY_AUTH_TOKEN is only
# needed at build time for source-map upload and release tagging.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# Opt-in to session replay (1% normal, 100% on errors).
# NEXT_PUBLIC_SENTRY_REPLAY=1
